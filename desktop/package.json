{
  "name": "pegasus-desktop",
  "productName": "Pegasus",
  "version": "0.1.0",
  "description": "Connecte Claude Code aux sites WordPress d'Orphic Agency.",
  "author": "Orphic Agency",
  "license": "UNLICENSED",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.orphicagency.pegasus",
    "productName": "Pegasus",
    "files": ["main.js", "preload.js", "app-config.json", "renderer/**"],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "identity": null
    },
    "dmg": {
      "title": "Installer Pegasus"
    }
  }
}
